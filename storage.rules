rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // =============================================
    // USER AVATARS
    // Users can only upload/read their own avatar
    // =============================================
    match /users/{userId}/avatar.webp {
      allow read: if true; // Avatars are publicly viewable (profile pics)
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024  // Max 2MB
                   && request.resource.contentType.matches('image/.*'); // Images only
    }

    // =============================================
    // COMPETITION IMAGES
    // Only admins can upload; anyone can view
    // =============================================
    match /competitions/{allPaths=**} {
      allow read: if true; // Competition banners are public
      allow write: if request.auth != null
                   && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType.matches('image/.*');
    }

    // =============================================
    // PROBLEM STATEMENTS JSON
    // Public read for ParamX; admin write only
    // =============================================
    match /problems.json {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // =============================================
    // PAYMENT PROOFS (Manual Registration)
    // Only admins can upload; admins can read
    // =============================================
    match /payment_proofs/{allPaths=**} {
      allow read: if request.auth != null
                   && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
      allow write: if request.auth != null
                   && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType.matches('image/.*');
    }

    // =============================================
    // CATCH-ALL: Deny everything else
    // =============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
